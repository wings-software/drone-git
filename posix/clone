#!/bin/sh

set -e

# if PLUGIN_ONLY_COPY_FILE_CONTENT is set, only copy the file content
if [ "$PLUGIN_ONLY_COPY_FILE_CONTENT" = "true" ]; then
	copy-file-content
	exit 0
fi

# force the home directory path.
if [ "$HOME" != "/home/drone" ]; then
	if [ -d "/home/drone" ]; then
		echo "[DEBUG] setting default home directory"
		export HOME=/home/drone
	fi
fi

if [ ! -z "${DRONE_WORKSPACE}" ]; then
	mkdir -p ${DRONE_WORKSPACE}
	cd ${DRONE_WORKSPACE}
fi

# if the netrc enviornment variables exist, write
# the netrc file.

if [ ! -z "${DRONE_NETRC_MACHINE}" ]; then
	cat <<EOF > ${HOME}/.netrc
machine ${DRONE_NETRC_MACHINE}
login ${DRONE_NETRC_USERNAME}
password ${DRONE_NETRC_PASSWORD}
EOF
fi

# if the ssh_key environment variable exists, write
# the ssh key and add the netrc machine to the
# known hosts file.

if [ ! -z "${DRONE_SSH_KEY}" ]; then
	mkdir -p ${HOME}/.ssh
	echo "$DRONE_SSH_KEY" > ${HOME}/.ssh/id_rsa
	chmod 600 ${HOME}/.ssh/id_rsa

	touch ${HOME}/.ssh/known_hosts
	chmod 600 ${HOME}/.ssh/known_hosts

	SSH_PORT_FLAG=""
	if [ ! -z "${DRONE_NETRC_PORT}" ]; then
		SSH_PORT_FLAG="-p ${DRONE_NETRC_PORT}"
	fi

	SSH_KEYSCAN_TIMEOUT_FLAG=""
	if [ ! -z "${PLUGIN_SSH_KEYSCAN_TIMEOUT}" ]; then
		SSH_KEYSCAN_TIMEOUT_FLAG="-T ${PLUGIN_SSH_KEYSCAN_TIMEOUT}"
	fi

	if [ ! -z "${DRONE_SSH_PASSPHRASE}" ]; then
		ssh-keygen -p -f ${HOME}/.ssh/id_rsa -P ${DRONE_SSH_PASSPHRASE} -N ""
	fi

	# --- DEBUG START ---
	echo "[DEBUG] ============================================"
	echo "[DEBUG] SSH CLONE DIAGNOSTICS"
	echo "[DEBUG] ============================================"
	echo "[DEBUG] DRONE_NETRC_MACHINE=${DRONE_NETRC_MACHINE}"
	echo "[DEBUG] DRONE_NETRC_PORT=${DRONE_NETRC_PORT:-22 (default)}"
	echo "[DEBUG] SSH_PORT_FLAG=${SSH_PORT_FLAG}"
	echo "[DEBUG] SSH_KEYSCAN_TIMEOUT_FLAG=${SSH_KEYSCAN_TIMEOUT_FLAG}"
	echo "[DEBUG] PLUGIN_SSH_KEYSCAN_TIMEOUT=${PLUGIN_SSH_KEYSCAN_TIMEOUT}"
	echo "[DEBUG] HOME=${HOME}"
	echo "[DEBUG]"
	echo "[DEBUG] --- Step 1: DNS Resolution ---"
	nslookup ${DRONE_NETRC_MACHINE} 2>&1 || echo "[DEBUG] nslookup not available, trying getent..."
	getent hosts ${DRONE_NETRC_MACHINE} 2>&1 || echo "[DEBUG] getent also failed — DNS resolution BROKEN"
	echo "[DEBUG]"
	echo "[DEBUG] --- Step 2: SSH Port Connectivity (port ${DRONE_NETRC_PORT:-22}, 5s timeout) ---"
	timeout 5 bash -c "echo > /dev/tcp/${DRONE_NETRC_MACHINE}/${DRONE_NETRC_PORT:-22}" 2>&1 && echo "[DEBUG] RESULT: Port ${DRONE_NETRC_PORT:-22} is OPEN" || echo "[DEBUG] RESULT: Port ${DRONE_NETRC_PORT:-22} is CLOSED/UNREACHABLE — this is why ssh-keyscan hangs"
	echo "[DEBUG]"
	echo "[DEBUG] --- Step 3: SSH Config File Permissions ---"
	ls -la /etc/ssh/ssh_config 2>&1 || echo "[DEBUG] /etc/ssh/ssh_config not found"
	ls -la /etc/ssh/ssh_config.d/ 2>&1 || echo "[DEBUG] /etc/ssh/ssh_config.d/ not found"
	echo "[DEBUG]"
	echo "[DEBUG] --- Step 4: SSH Key Validation ---"
	ssh-keygen -l -f ${HOME}/.ssh/id_rsa 2>&1 || echo "[DEBUG] SSH key is INVALID or unreadable"
	echo "[DEBUG]"
	echo "[DEBUG] --- Step 5: ssh-keyscan (10s timeout, stderr visible) ---"
	timeout 10 ssh-keyscan -v -H ${SSH_PORT_FLAG} ${SSH_KEYSCAN_TIMEOUT_FLAG} ${DRONE_NETRC_MACHINE} > ${HOME}/.ssh/known_hosts 2>&1
	SSH_KEYSCAN_EXIT=$?
	if [ ${SSH_KEYSCAN_EXIT} -eq 0 ]; then
		echo "[DEBUG] RESULT: ssh-keyscan SUCCEEDED (exit code 0)"
	elif [ ${SSH_KEYSCAN_EXIT} -eq 124 ]; then
		echo "[DEBUG] RESULT: ssh-keyscan TIMED OUT after 10s (exit code 124)"
		echo "[DEBUG] ROOT CAUSE: The host ${DRONE_NETRC_MACHINE}:${DRONE_NETRC_PORT:-22} is not reachable on SSH port"
		echo "[DEBUG] ACTION: Check firewall/network policies allowing pod -> ${DRONE_NETRC_MACHINE}:${DRONE_NETRC_PORT:-22}"
	else
		echo "[DEBUG] RESULT: ssh-keyscan FAILED (exit code ${SSH_KEYSCAN_EXIT})"
	fi
	echo "[DEBUG]"
	echo "[DEBUG] --- Step 6: known_hosts result ---"
	if [ -s ${HOME}/.ssh/known_hosts ]; then
		echo "[DEBUG] known_hosts has content (keyscan worked):"
		cat ${HOME}/.ssh/known_hosts 2>&1
	else
		echo "[DEBUG] known_hosts is EMPTY — host key was NOT retrieved"
	fi
	echo "[DEBUG]"
	echo "[DEBUG] --- Step 7: Direct SSH test (5s timeout) ---"
	timeout 5 ssh -v -o StrictHostKeyChecking=no -i ${HOME}/.ssh/id_rsa ${SSH_PORT_FLAG} -F /dev/null ${DRONE_NETRC_MACHINE} "echo SSH_OK" 2>&1 || echo "[DEBUG] Direct SSH connection FAILED"
	echo "[DEBUG] ============================================"
	echo "[DEBUG] Continuing clone attempt regardless of above results..."
	echo "[DEBUG] ============================================"
	# --- DEBUG END ---

	export GIT_SSH_COMMAND="ssh -v -o UserKnownHostsFile=${HOME}/.ssh/known_hosts -i ${HOME}/.ssh/id_rsa ${SSH_PORT_FLAG} -F /dev/null"
fi

# AWS codecommit support using AWS access key & secret key
# Refer: https://docs.aws.amazon.com/codecommit/latest/userguide/setting-up-https-unixes.html

if [ ! -z "$DRONE_AWS_ACCESS_KEY" ]; then
	aws configure set aws_access_key_id $DRONE_AWS_ACCESS_KEY
	aws configure set aws_secret_access_key $DRONE_AWS_SECRET_KEY
	aws configure set default.region $DRONE_AWS_REGION

	git config --global credential.helper '!aws codecommit credential-helper $@'
	git config --global credential.UseHttpPath true
fi

# configure git global behavior and parameters via the
# following environment variables:


if [ -z "${DRONE_COMMIT_AUTHOR_NAME}" ]; then
	export DRONE_COMMIT_AUTHOR_NAME=drone
fi

if [ -z "${DRONE_COMMIT_AUTHOR_EMAIL}" ]; then
	export DRONE_COMMIT_AUTHOR_EMAIL=drone@localhost
fi

export GIT_AUTHOR_NAME=${DRONE_COMMIT_AUTHOR_NAME}
export GIT_AUTHOR_EMAIL=${DRONE_COMMIT_AUTHOR_EMAIL}
export GIT_COMMITTER_NAME=${DRONE_COMMIT_AUTHOR_NAME}
export GIT_COMMITTER_EMAIL=${DRONE_COMMIT_AUTHOR_EMAIL}

# invoke the sub-script based on the drone event type.
# TODO we should ultimately look at the ref, since
# we need something compatible with deployment events.

CLONE_TYPE=$DRONE_BUILD_EVENT
case $DRONE_COMMIT_REF in
  refs/tags/* ) CLONE_TYPE=tag ;;
  refs/pull/* ) CLONE_TYPE=pull_request ;;
  refs/pull-request/* ) CLONE_TYPE=pull_request ;;
  refs/merge-requests/* ) CLONE_TYPE=pull_request ;;
esac

common

case $CLONE_TYPE in
pull_request)
	clone-pull-request
	;;
tag)
	clone-tag
	;;
*)
	clone-commit
	;;
esac

post-fetch

copy-file-content

if [ -n "$PLUGIN_BUILD_TOOL_FILE" ] && [ -z "$CI_DISABLE_TELEMETRY" ]; then
    get-buildtool-lang || true
fi